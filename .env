NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000

# Database (MySQL)
#DATABASE_URL="mysql://user:password@localhost:3306/afristream_db"


#DB_CONNECTION = mysql	
#DB_HOST	= localhost or 127.0.0.1
#DB_PORT	= 3306	
#DB_NAME	= afristream_db	
#DB_USER	= root	
#DB_PASSWORD	= 

DB_CONNECTION = mysql	
DB_HOST	= 127.0.0.1
DB_PORT	= 3306	
DB_NAME	= afristream_db	
DB_USER	= root	
DB_PASSWORD	= 

# Auth
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Paystack
PAYSTACK_SECRET=replace-with-paystack-secret
PAYSTACK_WEBHOOK_SECRET=replace-with-webhook-secret

# CORS
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
ADMIN_ORIGIN=http://localhost:5174
NODE_ENV=development
BASE_URL=http://localhost:5000


# Storage
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Uploads
MAX_FILE_SIZE=10000000
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp


# External Services
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@afristream.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-key

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://afristream.com


